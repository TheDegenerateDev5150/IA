nmap -p 22 --script CVE-2024-6387.nse <IP>
# O copiar el script del repo: https://github.com/hackingyseguridad/ssha/blob/master/CVE-2024-6387.nse

# POC de verificaciГѓВіn en Python (repo ssha)
python3 CVE-2024-6387.py <IP>

# Compilar exploit en C (repo ssha Гўв‚¬вЂќ requiere entorno controlado/autorizado)
